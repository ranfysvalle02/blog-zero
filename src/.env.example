# ── Required ─────────────────────────────────────────────
# CHANGE ALL VALUES BEFORE DEPLOYING TO PRODUCTION.
# The defaults below are intentionally weak and for local development only.

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME_use_a_strong_password

# Must be >= 32 characters. Generate with:  openssl rand -base64 48
MDB_JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_48
MDB_ENGINE_MASTER_KEY=CHANGE_ME_generate_with_openssl_rand_base64_48

# ── Optional ─────────────────────────────────────────────
# Webhook secrets (used by http hook actions)
# SLACK_TOKEN=xoxb-your-slack-token
